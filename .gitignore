# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# env.md = salinan .env berisi rahasia (OAuth/DB) — JANGAN commit.
env.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# seed run reports (generated per-run, lihat prisma/seed/lib/report.ts)
/prisma/seed/reports

# Foto unggahan (fallback lokal saat S3 belum dikonfigurasi)
.uploads/

# ===================================================================
# Kustomisasi Tambahan untuk Project Fullstack & Multi-Platform
# ===================================================================

# Mengabaikan cache dan konfigurasi IDE (Android Studio / VS Code / Cursor)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.claude/

# Mengabaikan file log internal dan blueprint presentasi
*.lock
*.pptx

# Mengabaikan build dan cache Flutter di dalam folder mobile
mobile/build/
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.flutter-plugins-version

mobile/dist/
*.apk