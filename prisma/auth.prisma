model User {
  id                  String                 @id @default(cuid())
  name                String?
  /// Login non-Google (petugas lapangan, staf internal) memakai username,
  /// bukan email. Email tetap wajib & unik untuk akun Google.
  username            String?                @unique
  email               String                 @unique
  emailVerified       DateTime?
  image               String?
  /// Hash bcrypt untuk login Credentials. Null untuk akun yang hanya
  /// login via Google (OAuth-only).
  passwordHash        String?
  role                Role                   @default(USER)
  status              UserStatus             @default(ACTIVE)
  twoFactorEnabled    Boolean                @default(false)
  divisiId            String?
  bagianId            String?
  subBagianId         String?
  /// Denormalized dari divisi/subBagian — dibaca langsung di JWT/session
  /// (lihat auth.ts callbacks.jwt) supaya authorization check di edge
  /// middleware (proxy.ts) tidak perlu query Prisma. WAJIB tetap sinkron
  /// dengan divisiId/subBagianId setiap kali penempatan user diubah.
  divisiKode          String?
  subBagianKode       String?
  lastLoginAt         DateTime?
  loginCount          Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  accounts            Account[]
  auditLogs           AuditLog[]
  langgananWarga      LanggananWarga[]
  laporanVerif1       LaporanHarianPetugas[] @relation("LaporanVerif1")
  laporanVerif2       LaporanHarianPetugas[] @relation("LaporanVerif2")
  laporanVerif3       LaporanHarianPetugas[] @relation("LaporanVerif3")
  laporanDiverifikasi LaporanHarianPetugas[] @relation("LaporanVerifikator")
  laporanMandiriVerif LaporanMandiri[]       @relation("LaporanMandiriVerifikator")
  mutasiDiproses      MutasiPelanggan[]      @relation("MutasiProsesOleh")
  pelangganDibuat     Pelanggan[]            @relation("PelangganAuthor")
  pelangganDiupdate   Pelanggan[]            @relation("PelangganLastEditor")
  pemutusanDiproses   Pemutusan[]            @relation("PemutusanProsesOleh")
  pencatat            Pencatat?
  pengaduanDitugaskan Pengaduan[]            @relation("PengaduanDitugaskan")
  pengaduanEskalasi   Pengaduan[]            @relation("PengaduanEskalasi")
  riwayatPengaduan    RiwayatPengaduan[]     @relation("RiwayatPengaduanOleh")
  sessions            Session[]
  tagihanDivalidasi   Tagihan[]              @relation("TagihanValidator")
  twoFactors          TwoFactor[]
  bagian              Bagian?                @relation(fields: [bagianId], references: [id])
  divisi              Divisi?                @relation(fields: [divisiId], references: [id])
  subBagian           SubBagian?             @relation(fields: [subBagianId], references: [id])

  @@index([email])
  @@index([username])
  @@index([role, status])
  @@map("user")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  password          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor")
}

enum Role {
  SUPER_ADMIN
  DIREKSI
  SENIOR_MANAGER
  MANAGER
  SUPERVISOR
  STAFF
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
